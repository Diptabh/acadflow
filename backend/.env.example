# acadflow Backend Environment Variables
# Copy this file to .env and fill in your values

# Application
APP_NAME=AcadFlow API
APP_VERSION=1.0.0
DEBUG=false

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT Authentication
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (Resend API - https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=AcadFlow <noreply@yourdomain.com>
